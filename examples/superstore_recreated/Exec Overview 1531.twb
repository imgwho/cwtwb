      <aliases enabled='yes' />
      <column caption='Current Year Sales' datatype='real' default-format='c&quot;£&quot;#,##0;-&quot;£&quot;#,##0' name='[Calculation_2657968219434340352]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF &#13;&#10;YEAR([Order Date]) = [Parameters].[Parameter 3]&#13;&#10;THEN &#13;&#10;[Sales]&#13;&#10;END' />
      </column>
      <column caption='Previous Year Sales' datatype='real' default-format='c&quot;£&quot;#,##0;-&quot;£&quot;#,##0' name='[Calculation_2657968219434618881]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF &#13;&#10;YEAR([Order Date]) = [Parameters].[Parameter 3]-1&#13;&#10;THEN &#13;&#10;[Sales]&#13;&#10;END' />
      </column>
      <column caption='Sales Difference' datatype='real' default-format='*+0.0%;-0.0%' name='[Calculation_2657968219436978179]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Calculation_2657968219434340352]) - SUM([Calculation_2657968219434618881]))&#13;&#10;/&#13;&#10;SUM([Calculation_2657968219434618881])' />
      </column>
      <column caption='Previous Year' datatype='integer' default-format='n0;-0' name='[Calculation_2657968219438084100]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Parameters].[Parameter 3] - 1' />
      </column>
      <column caption='Returns count (order date)' datatype='integer' name='[Calculation_2657968219769372684]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ fixed [Order Date]&#13;&#10;&#13;&#10;: &#13;&#10;&#13;&#10;count ( [Returned] ) &#13;&#10;&#13;&#10;}' />
      </column>
      <column caption='Sales Color Filter (KPI)' datatype='string' name='[Calculation_2657968219775717391]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2657968219436978179] &gt; 0 &#13;&#10;THEN &apos;GOOD&apos;&#13;&#10;ELSE &#13;&#10;&apos;BAD&apos;&#13;&#10;END' />
      </column>
      <column caption='dummy' datatype='string' name='[Calculation_2657968219784581146]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&apos;dummy&apos;' />
      </column>
      <column caption='Days to Ship' datatype='integer' name='[Calculation_2657968219801149477]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,[Order Date],[Ship Date])' />
      </column>
      <column caption='Profit color (table)' datatype='string' name='[Calculation_2657968219803041830]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF &#13;&#10;{FIXED [Order ID]:&#13;&#10;SUM([Profit])&gt;0 }&#13;&#10;THEN &apos;YES&apos;&#13;&#10;ELSE &apos;NO&apos;&#13;&#10;END' />
      </column>
      <column caption='Button Highlight' datatype='string' name='[Calculation_4058024754198179840]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 3] = DATEPART(&apos;year&apos;, [Order Date]) THEN &apos;RED&apos;&#13;&#10;ELSE &apos;BLIUE&apos;&#13;&#10;END' />
      </column>
      <column caption='Days to ship FLAG' datatype='string' name='[Calculation_4058024754241245185]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF &#13;&#10;[Calculation_2657968219801149477]&gt;=[Parameters].[Parameter 4] THEN &apos;⬤&apos;&#13;&#10;ELSE &apos;&apos; &#13;&#10;END' />
      </column>
      <column caption='Year Filter' datatype='boolean' name='[Calculation_4058024754263076867]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='year([Order Date]) = [Parameters].[Parameter 3]' />
      </column>
      <column caption='Days to Ship param title' datatype='integer' name='[Calculation_4058024754265350148]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Parameters].[Parameter 4]' />
      </column>
      <column caption='Days to ship + 1' datatype='integer' name='[Calculation_4058024754278920197]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Parameters].[Parameter 4]+1' />
      </column>
      <column caption='Custom Sort by ' datatype='real' name='[Calculation_4058024754284548110]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 5]&#13;&#10;&#13;&#10;WHEN &apos;Profit&apos; THEN &#13;&#10;-SUM({FIXED [Order ID]: SUM([Profit]) })&#13;&#10;&#13;&#10;WHEN &apos;Sales&apos; THEN &#13;&#10;&#13;&#10;-SUM({FIXED [Order ID]: SUM([Sales])})&#13;&#10;&#13;&#10;WHEN &apos;Days to Ship&apos; THEN &#13;&#10;&#13;&#10;-AVG([Calculation_2657968219801149477])&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Rank CY' datatype='integer' name='[Calculation_4058024754292973583]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(sum([Calculation_2657968219434340352]),&apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Sales Target' datatype='real' default-format='c&quot;£&quot;#,##0;-&quot;£&quot;#,##0' name='[Calculation_4058024754295590933]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_2657968219434618881]*[Parameters].[Parameter 6]' />
      </column>
      <column caption='Target Reached' datatype='string' name='[Calculation_4058024754299007009]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF &#13;&#10;SUM([Calculation_2657968219434340352]) &gt;= SUM([Calculation_4058024754295590933])&#13;&#10;THEN &apos;⬤&apos;&#13;&#10;ELSE &apos; &apos;&#13;&#10;END' />
      </column>
      <column caption='Difference from Target' datatype='real' default-format='*+&quot;£&quot;#,##0,.0K;-&quot;£&quot;#,##0,.0K' name='[Calculation_4058024754579435558]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Calculation_2657968219434340352]) - SUM([Calculation_4058024754295590933]) )' />
      </column>
      <column caption='CY Sales Total' datatype='real' name='[Calculation_4058024754620833837]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED: SUM([Calculation_2657968219434340352])}' />
      </column>
      <column caption='CY Total Sales/Subcat' datatype='real' name='[Calculation_4058024754621104174]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Sub-Category]: SUM([Calculation_2657968219434340352]) }' />
      </column>
      <column caption='% of total sales CY' datatype='real' default-format='p0.0%' name='[Calculation_4058024754621308975]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_4058024754621104174]) / SUM([Calculation_4058024754620833837])' />
      </column>
      <column caption='Other % of total' datatype='real' name='[Calculation_4058024754621444144]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1-[Calculation_4058024754621308975]' />
      </column>
      <column caption='Sales Percentage' datatype='real' name='[Calculation_4058024754625110070]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([Calculation_2657968219434340352]) &gt;= SUM([Calculation_4058024754295590933])&#13;&#10;&#13;&#10;THEN 1.00&#13;&#10;ELSE &#13;&#10;&#13;&#10;1-(&#13;&#10;&#13;&#10;&#13;&#10;SUM(&#13;&#10;{ INCLUDE [Segment]: SUM([Calculation_4058024754295590933]) })&#13;&#10;&#13;&#10;-&#13;&#10;&#13;&#10;SUM(&#13;&#10;{ INCLUDE [Segment]: SUM([Calculation_2657968219434340352])})&#13;&#10;&#13;&#10;)&#13;&#10;/&#13;&#10;SUM(&#13;&#10;{ (SUM([Calculation_4058024754295590933]))})&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Bottom Half of gauge' datatype='integer' name='[Calculation_4058024754625519671]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MIN(1)' />
      </column>
      <column caption='Colored&lt;50' datatype='real' name='[Calculation_4058024754625974328]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF &#13;&#10;[Calculation_4058024754625110070] &lt; 0.5&#13;&#10;THEN &#13;&#10;[Calculation_4058024754625110070]&#13;&#10;ELSE 0.5&#13;&#10;END' />
      </column>
      <column caption='Grey&lt;50' datatype='real' name='[Calculation_4058024754626150457]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_4058024754625110070] &lt; 0.5&#13;&#10;THEN &#13;&#10;0.5-[Calculation_4058024754625110070]&#13;&#10;END' />
      </column>
      <column caption='Colored&gt;50' datatype='real' name='[Calculation_4058024754626293818]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_4058024754625110070] &gt; 0.5&#13;&#10;THEN&#13;&#10;[Calculation_4058024754625110070]-0.5&#13;&#10;END' />
      </column>
      <column caption='Grey&gt;50' datatype='real' name='[Calculation_4058024754626461755]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_4058024754625110070] &gt; 0.5&#13;&#10;THEN&#13;&#10;1-[Calculation_4058024754625110070]&#13;&#10;ELSE 0.5&#13;&#10;END' />
      </column>
      <column caption='Pointer 1' datatype='real' name='[Calculation_4058024754626760764]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF &#13;&#10;[Calculation_4058024754625110070]&lt;= 0.5&#13;&#10;THEN 0.005 END' />
      </column>
      <column caption='Gauge dummy' datatype='string' name='[Calculation_4058024754627919934]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&apos;dummy&apos;' />
      </column>
