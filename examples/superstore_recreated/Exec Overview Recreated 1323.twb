      <column caption='Sales Target' datatype='real'
        name='[Calculation_0AFA02EDFF304AA89F66C71815DF94B8]' role='measure' type='quantitative'>
        <calculation class='tableau'
          formula='[Calculation_AD4A045F87A14E158E89E88854E55176]*[Parameters].[Parameter 2]' />
      </column>
      <column caption='Previous Year Returns' datatype='integer'
        name='[Calculation_0B95AE9541D1417FB8458D3108C0F364]' role='measure' type='quantitative'>
        <calculation class='tableau'
          formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1]-1 THEN [Calculation_9B4ED08A1F8341AC91D8924D0E61A873] END' />
      </column>
      <column caption='Current Year Profit' datatype='real'
        name='[Calculation_0EE6CEC3AB1F403CA41C53DBD31E61DF]' role='measure' type='quantitative'>
        <calculation class='tableau'
          formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Profit] END' />
      </column>
      <column caption='Previous Year Quantity' datatype='integer'
        name='[Calculation_1CEFC6BBC89B4E93A6322305763165A3]' role='measure' type='quantitative'>
        <calculation class='tableau'
          formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1]-1 THEN [Quantity] END' />
      </column>
      <column caption='Quantity Difference' datatype='real'
        name='[Calculation_1E159D5E961243E0A4897E23F1373D38]' role='measure' type='quantitative'>
        <calculation class='tableau'
          formula='(SUM([Calculation_C0FFC3CB0A2145DD88AB547A884DB8CE]) - SUM([Calculation_1CEFC6BBC89B4E93A6322305763165A3])) / SUM([Calculation_1CEFC6BBC89B4E93A6322305763165A3])' />
      </column>
      <column caption='Target Reached' datatype='string'
        name='[Calculation_28810BD9A3C3494791365B9B14F752C9]' role='measure' type='nominal'>
        <calculation class='tableau'
          formula='IF SUM([Calculation_781351269A5E48CAA34FEAD44C0AA3A4]) &gt;= SUM([Calculation_0AFA02EDFF304AA89F66C71815DF94B8]) THEN &apos;⬤&apos; ELSE &apos; &apos; END' />
      </column>
      <column caption='dummy' datatype='string'
        name='[Calculation_2B69C107684A4E9E9660335F91EFE2BF]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&apos;dummy&apos;' />
      </column>
      <column caption='Sales Difference' datatype='real'
        name='[Calculation_3CF3C20A53EC4504A77813EFDEE10EB3]' role='measure' type='quantitative'>
        <calculation class='tableau'
          formula='(SUM([Calculation_781351269A5E48CAA34FEAD44C0AA3A4]) - SUM([Calculation_AD4A045F87A14E158E89E88854E55176])) / SUM([Calculation_AD4A045F87A14E158E89E88854E55176])' />
      </column>
      <column caption='Previous Year Profit' datatype='real'
        name='[Calculation_40FF6E8E3F394E7799626135E746B0FE]' role='measure' type='quantitative'>
        <calculation class='tableau'
          formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1]-1 THEN [Profit] END' />
      </column>
      <column caption='CY Total Sales Subcat' datatype='real'
        name='[Calculation_447290D6499A4469A70AB4458A9F6B2D]' role='measure' type='quantitative'>
        <calculation class='tableau'
          formula='{ FIXED [Sub-Category]: SUM([Calculation_781351269A5E48CAA34FEAD44C0AA3A4]) }' />
      </column>
      <column caption='KPI Bar Profit' datatype='integer'
        name='[Calculation_44F26E15B38E45A5A6EC6E997BA6F730]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MIN(1)' />
