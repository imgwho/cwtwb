              param-domain-type='list' role='measure' type='quantitative' value='2023'>
              <calculation class='tableau' formula='2023' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0ahyg8e1xelf3914bag3r0yukuro'>
            <column caption='Current Year Profit' datatype='real'
              name='[Calculation_0EE6CEC3AB1F403CA41C53DBD31E61DF]' role='measure'
              type='quantitative'>
              <calculation class='tableau'
                formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Profit] END' />
            </column>
            <column caption='Previous Year Profit' datatype='real'
              name='[Calculation_40FF6E8E3F394E7799626135E746B0FE]' role='measure'
              type='quantitative'>
              <calculation class='tableau'
                formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1]-1 THEN [Profit] END' />
            </column>
            <column caption='KPI Bar Profit' datatype='integer'
              name='[Calculation_44F26E15B38E45A5A6EC6E997BA6F730]' role='measure'
