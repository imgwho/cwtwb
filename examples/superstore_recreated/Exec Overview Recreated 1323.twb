              name='[Calculation_8E6B1A53C9564507BE5CF9FBF5B3D6A9]' role='measure'
              type='quantitative'>
              <calculation class='tableau'
                formula='(SUM([Calculation_0EE6CEC3AB1F403CA41C53DBD31E61DF]) - SUM([Calculation_40FF6E8E3F394E7799626135E746B0FE])) / SUM([Calculation_40FF6E8E3F394E7799626135E746B0FE])' />
