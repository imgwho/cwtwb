              <calculation class='tableau' formula='IF SUM([Calculation_BBB5E137D6D243CB96596B3B749F4E6C]) &gt;= SUM([Calculation_8DF6D86A6D1540B38EBD80D3FF2E4230]) THEN &apos;⬤&apos; ELSE &apos; &apos; END' />
