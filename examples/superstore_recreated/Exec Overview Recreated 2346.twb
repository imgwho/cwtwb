      <aliases enabled='yes' />
      <column caption='Profit Difference' datatype='real' name='[Calculation_073A6751A7C34AFC87D7FFBE6784241F]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Calculation_1027071246D94B4CA4D868A668EE7619]) - SUM([Calculation_9E18F97E915E487CA28259B314B25805])) / SUM([Calculation_9E18F97E915E487CA28259B314B25805])' />
      </column>
      <column caption='Current Year Profit' datatype='real' name='[Calculation_1027071246D94B4CA4D868A668EE7619]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Profit] END' />
      </column>
      <column caption='Returns count' datatype='integer' name='[Calculation_136B0AB8F4E74431A4951243AA47C57F]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Order Date]: COUNT([Order ID]) }' />
      </column>
      <column caption='Current Year Sales' datatype='real' name='[Calculation_1A2CAD890C7845AA8640DFC6C2D5E9B9]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Sales] END' />
