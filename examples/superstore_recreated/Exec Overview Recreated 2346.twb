      <column caption='Previous Year Sales' datatype='real' name='[Calculation_1BAF278565084D0584F06FA98D27DA90]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1]-1 THEN [Sales] END' />
      </column>
      <column caption='CY Sales Total' datatype='real' name='[Calculation_236836BF70964D419F7B1B8EAF3355D0]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED: SUM([Calculation_1A2CAD890C7845AA8640DFC6C2D5E9B9])}' />
      </column>
      <column caption='Returns Color Filter' datatype='string' name='[Calculation_25E7078AB3634711B64C0037CA976404]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_793F5783EFB84333BFCEEEB94769FA9C] &lt; 0 THEN &apos;GOOD&apos; ELSE &apos;BAD&apos; END' />
