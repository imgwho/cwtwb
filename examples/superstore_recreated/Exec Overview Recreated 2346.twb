              <calculation class='tableau' formula='IF SUM([Calculation_1A2CAD890C7845AA8640DFC6C2D5E9B9]) &gt;= SUM([Calculation_BCDF63C7350841BF9EDBC77D45EA13EA]) THEN &apos;⬤&apos; ELSE &apos; &apos; END' />
